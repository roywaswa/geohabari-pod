---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.scss';
import '../styles/globals.css'

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  darkHero?: boolean;
}

const {
  title = 'GeoHabari',
  description = 'Amplifying African Geo-Tech Stories & Elevating Technical Brilliance',
  url = 'https://www.geohabari.com',
  image = '/og-image.jpg',
  darkHero = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />

    <!-- Basic SEO -->
    <title>{title} | GeoHabari</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | GeoHabari`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | GeoHabari`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Performance Hints -->
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured Data (Schema.org JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "GeoHabari",
        "url": "https://www.geohabari.com",
        "description": "Geohabari Podcast is a platform for us to tell our african tech stories for everyone from aspiring professionals to seasoned veterans. There is something for you.",
        "publisher": {
          "@type": "Organization",
          "name": "GeoHabari",
          "logo": {
            "@type": "ImageObject",
            "url": "/logo.png"
          }
        }
      }
    </script>
  </head>

  <body class={darkHero ? 'dark-hero' : ''}>

    <!-- Intro loader — 7-dot logo pattern -->
    <div class="intro-loader" id="introLoader">
      <div class="loader-dots" id="loaderDots">
        <!-- Row 1: ● ● _ -->
        <div class="loader-dot d1"></div>
        <div class="loader-dot d2"></div>
        <div class="loader-dot empty"></div>
        <!-- Row 2: ● ● ● -->
        <div class="loader-dot d3"></div>
        <div class="loader-dot d4"></div>
        <div class="loader-dot d5"></div>
        <!-- Row 3: _ ● ● -->
        <div class="loader-dot empty"></div>
        <div class="loader-dot d6"></div>
        <div class="loader-dot d7"></div>
      </div>
    </div>

    <!-- Custom cursor (desktop only) -->
    <div class="cursor-dot" id="cursorDot"></div>
    <div class="cursor-ring" id="cursorRing"></div>

    <Header darkHero={darkHero} />
    <main id="content" role="main">
      <slot />
    </main>
    <Footer />

    <script>
      // === INTRO LOADER — dots pop in, then pulse, then dismiss ===
      window.addEventListener("load", () => {
        const loader = document.getElementById("introLoader");
        const dots = document.getElementById("loaderDots");
        if (!loader || !dots) return;
        setTimeout(() => dots.classList.add("pulse"), 600);
        setTimeout(() => {
          loader.classList.add("done");
          setTimeout(() => loader.remove(), 600);
        }, 1400);
      });

      // === CUSTOM CURSOR ===
      const dot = document.getElementById("cursorDot");
      const ring = document.getElementById("cursorRing");
      if (dot && ring && window.matchMedia("(pointer: fine)").matches) {
        let mx = 0, my = 0, rx = 0, ry = 0;

        document.addEventListener("mousemove", (e) => {
          mx = e.clientX; my = e.clientY;
          dot.style.transform = `translate(${mx - 4}px, ${my - 4}px)`;
        });

        function animateRing() {
          rx += (mx - rx) * 0.15;
          ry += (my - ry) * 0.15;
          ring.style.transform = `translate(${rx - 20}px, ${ry - 20}px)`;
          requestAnimationFrame(animateRing);
        }
        animateRing();

        document.querySelectorAll("a, button, .card-theme, .ep-card, .platform-pill, .cta-primary, .cta-secondary").forEach(el => {
          el.addEventListener("mouseenter", () => {
            ring.classList.add("hover");
            dot.classList.add("hover");
          });
          el.addEventListener("mouseleave", () => {
            ring.classList.remove("hover");
            dot.classList.remove("hover");
          });
        });
      } else {
        dot?.remove();
        ring?.remove();
      }
    </script>
  </body>
</html>
